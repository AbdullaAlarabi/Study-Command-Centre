{
  "name": "study-command-centre",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "seed": "tsx --env-file=.env.seed scripts/seed.ts",
    "test:progress": "tsx --test scripts/progress.test.ts",
    "test:quiz": "tsx --test scripts/quiz.test.ts",
    "test:revision": "tsx --test scripts/revision.test.ts",
    "test:content": "tsx --test scripts/content-integration.test.ts",
    "test": "npm run test:progress && npm run test:quiz && npm run test:revision && npm run test:content",
    "content:audit": "tsx scripts/content-audit.ts",
    "content:import": "tsx --env-file=.env.seed scripts/import-academic-content.ts",
    "qa:phase7": "tsx --env-file=.env.seed scripts/phase7-browser-qa.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.52.1",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.7.0",
    "recharts": "^3.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "playwright-core": "^1.61.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "vite": "^6.0.7",
    "ws": "^8.21.1"
  }
}
